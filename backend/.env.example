# Copy to .env
OPENAI_API_KEY=sk-...
MODEL=openai/gpt-5.2
# Optional
ALLOWED_ORIGINS=*

# Admin dashboard secret (sent as x-admin-key)
ADMIN_SECRET=change-me

# SQLite file (default is backend/data/ardhiq.sqlite)
# DATABASE_URL=sqlite+pysqlite:///absolute/or/relative/path.sqlite

# OCR note: pytesseract requires the `tesseract` binary + language packs (ara, fra, eng).
